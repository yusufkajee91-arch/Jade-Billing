generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  fee_earner
  assistant
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  initials          String
  role              UserRole  @default(fee_earner)
  defaultFeeLevelId    String?   @map("default_fee_level_id")
  monthlyTargetCents   Int?      @map("monthly_target_cents")
  isActive             Boolean   @default(true) @map("is_active")
  totpSecret        String?   @map("totp_secret")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  defaultFeeLevel    FeeLevel?          @relation(fields: [defaultFeeLevelId], references: [id])
  clientsCreated     Client[]           @relation("ClientCreatedBy")
  mattersOwned       Matter[]           @relation("MatterOwner")
  mattersCreated     Matter[]           @relation("MatterCreatedBy")
  matterUsers        MatterUser[]       @relation("MatterUserAccess")
  matterUserGrants   MatterUser[]       @relation("MatterUserGrantedBy")
  ficaUploads        FicaDocument[]     @relation("FicaUploadedBy")
  matterAttachments  MatterAttachment[] @relation("AttachmentUploadedBy")
  matterNotes        MatterNote[]       @relation("NoteCreatedBy")
  diaryAssigned      DiaryEntry[]       @relation("DiaryAssignedTo")
  diaryCreated       DiaryEntry[]       @relation("DiaryCreatedBy")
  feeEntriesEarned   FeeEntry[]         @relation("FeeEntryEarner")
  feeEntriesCreated  FeeEntry[]         @relation("FeeEntryCreatedBy")
  invoicesCreated    Invoice[]          @relation("InvoiceCreatedBy")
  suppliersCreated   Supplier[]         @relation("SupplierCreatedBy")
  trustEntriesCreated   TrustEntry[]    @relation("TrustEntryCreatedBy")
  businessEntriesCreated BusinessEntry[] @relation("BusinessEntryCreatedBy")
  bankStatementsImported BankStatement[] @relation("StatementImporter")
  bankMatches            BankMatch[]     @relation("BankMatchCreator")

  @@map("users")
}

model FirmSettings {
  id                         String   @id @default(uuid())
  firmName                   String   @map("firm_name")
  tradingName                String?  @map("trading_name")
  logoFilePath               String?  @map("logo_file_path")
  vatRegistered              Boolean  @default(false) @map("vat_registered")
  vatRegistrationNumber      String?  @map("vat_registration_number")
  vatRateBps                 Int      @default(1500) @map("vat_rate_bps")
  trustBankName              String?  @map("trust_bank_name")
  trustBankAccountName       String?  @map("trust_bank_account_name")
  trustBankAccountNumber     String?  @map("trust_bank_account_number")
  trustBankBranchCode        String?  @map("trust_bank_branch_code")
  trustBankSwift             String?  @map("trust_bank_swift")
  businessBankName           String?  @map("business_bank_name")
  businessBankAccountName    String?  @map("business_bank_account_name")
  businessBankAccountNumber  String?  @map("business_bank_account_number")
  businessBankBranchCode     String?  @map("business_bank_branch_code")
  businessBankSwift          String?  @map("business_bank_swift")
  invoicePaymentInstructions String?  @map("invoice_payment_instructions")
  invoicePrefix              String   @default("INV") @map("invoice_prefix")
  invoiceNextNumber          Int      @default(1) @map("invoice_next_number")
  matterCodeAutoGenerate     Boolean  @default(true) @map("matter_code_auto_generate")
  billingBlocksEnabled       Boolean  @default(true) @map("billing_blocks_enabled")
  financialYearStartMonth    Int      @default(3) @map("financial_year_start_month")
  // Email / SMTP
  smtpHost                   String?  @map("smtp_host")
  smtpPort                   Int      @default(587) @map("smtp_port")
  smtpUser                   String?  @map("smtp_user")
  smtpPassword               String?  @map("smtp_password")
  smtpFromEmail              String?  @map("smtp_from_email")
  smtpFromName               String?  @map("smtp_from_name")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  offices FirmOffice[]

  @@map("firm_settings")
}

model FirmOffice {
  id             String       @id @default(uuid())
  firmSettingsId String       @map("firm_settings_id")
  label          String
  addressLine1   String?      @map("address_line_1")
  addressLine2   String?      @map("address_line_2")
  city           String?
  province       String?
  postalCode     String?      @map("postal_code")
  tel            String?
  email          String?
  website        String?
  isPrimary      Boolean      @default(false) @map("is_primary")
  sortOrder      Int          @default(0) @map("sort_order")

  firmSettings FirmSettings @relation(fields: [firmSettingsId], references: [id])

  @@map("firm_offices")
}

model FeeLevel {
  id              String   @id @default(uuid())
  name            String
  hourlyRateCents Int      @map("hourly_rate_cents")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  users User[]

  @@map("fee_levels")
}

model PostingCode {
  id              String  @id @default(uuid())
  code            String  @unique
  description     String
  defaultBillable Boolean @default(true) @map("default_billable")
  isActive        Boolean @default(true) @map("is_active")
  sortOrder       Int     @default(0) @map("sort_order")

  feeEntries FeeEntry[]

  @@map("posting_codes")
}

model MatterType {
  id        String  @id @default(uuid())
  name      String
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  matters Matter[]

  @@map("matter_types")
}

model FeeScheduleCategory {
  id           String            @id @default(uuid())
  name         String
  jurisdiction String
  currency     String            @default("ZAR")
  createdAt    DateTime          @default(now()) @map("created_at")

  items FeeScheduleItem[]

  @@map("fee_schedule_categories")
}

model FeeScheduleItem {
  id                   String              @id @default(uuid())
  categoryId           String              @map("category_id")
  section              String
  description          String
  officialFeeCents     Int                 @default(0) @map("official_fee_cents")
  professionalFeeCents Int                 @map("professional_fee_cents")
  vatRate              Decimal             @default(0.15) @map("vat_rate")
  isActive             Boolean             @default(true) @map("is_active")
  sortOrder            Int?                @map("sort_order")
  createdAt            DateTime            @default(now()) @map("created_at")

  category FeeScheduleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("fee_schedule_items")
}

model Department {
  id        String  @id @default(uuid())
  name      String
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  matters Matter[]

  @@map("departments")
}

enum EntityType {
  individual_sa
  company_pty
  company_ltd
  close_corporation
  trust
  partnership
  foreign_company
  other
}

enum FicaStatus {
  not_compliant
  partially_compliant
  compliant
}

model Client {
  id                    String     @id @default(uuid())
  clientCode            String     @unique @map("client_code")
  clientName            String     @map("client_name")
  entityType            EntityType @map("entity_type")
  emailGeneral          String?    @map("email_general")
  emailInvoices         String?    @map("email_invoices")
  emailStatements       String?    @map("email_statements")
  tel                   String?
  mobile                String?
  physicalAddressLine1  String?    @map("physical_address_line_1")
  physicalAddressLine2  String?    @map("physical_address_line_2")
  physicalCity          String?    @map("physical_city")
  physicalProvince      String?    @map("physical_province")
  physicalPostalCode    String?    @map("physical_postal_code")
  postalAddressLine1    String?    @map("postal_address_line_1")
  postalAddressLine2    String?    @map("postal_address_line_2")
  postalCity            String?    @map("postal_city")
  postalProvince        String?    @map("postal_province")
  postalPostalCode      String?    @map("postal_postal_code")
  vatNumber             String?    @map("vat_number")
  ficaStatus            FicaStatus @default(not_compliant) @map("fica_status")
  ficaNotes             String?    @map("fica_notes")
  ficaLastUpdatedAt     DateTime?  @map("fica_last_updated_at")
  isActive              Boolean    @default(true) @map("is_active")
  createdById           String     @map("created_by")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  createdBy     User           @relation("ClientCreatedBy", fields: [createdById], references: [id])
  ficaDocuments FicaDocument[]
  matters       Matter[]
  invoices      Invoice[]

  @@map("clients")
}

model FicaDocument {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  documentType  String   @map("document_type")
  fileName      String   @map("file_name")
  filePath      String   @map("file_path")
  fileSizeBytes Int?     @map("file_size_bytes")
  mimeType      String?  @map("mime_type")
  notes         String?
  uploadedById  String   @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  client     Client @relation(fields: [clientId], references: [id])
  uploadedBy User   @relation("FicaUploadedBy", fields: [uploadedById], references: [id])

  @@map("fica_documents")
}

model MatterCodeSequence {
  feeEarnerInitials String @map("fee_earner_initials")
  clientCode        String @map("client_code")
  lastSequence      Int    @default(0) @map("last_sequence")

  @@id([feeEarnerInitials, clientCode])
  @@map("matter_code_sequences")
}

enum MatterStatus {
  open
  closed
  suspended
}

enum BillingStatus {
  not_yet_billed
  awaiting_payment
  paid
}

enum NoteSource {
  manual
  from_fee_entry
}

model Matter {
  id           String       @id @default(uuid())
  matterCode   String       @unique @map("matter_code")
  clientId     String       @map("client_id")
  description  String
  matterTypeId String?      @map("matter_type_id")
  departmentId String?      @map("department_id")
  ownerId      String       @map("owner_id")
  status       MatterStatus @default(open)
  dateOpened   DateTime     @default(now()) @map("date_opened")
  dateClosed   DateTime?    @map("date_closed")
  notes        String?
  // Practice Notes fields
  matterStatusNote String?      @map("matter_status_note")
  toDo             Json?        @map("to_do")
  allocation       String?
  comment          String?
  billingStatus    BillingStatus @default(not_yet_billed) @map("billing_status")
  loeFicaDone      Boolean      @default(false) @map("loe_fica_done")
  createdById  String       @map("created_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  client       Client              @relation(fields: [clientId], references: [id])
  matterType   MatterType?         @relation(fields: [matterTypeId], references: [id])
  department   Department?         @relation(fields: [departmentId], references: [id])
  owner        User                @relation("MatterOwner", fields: [ownerId], references: [id])
  createdBy    User                @relation("MatterCreatedBy", fields: [createdById], references: [id])
  matterUsers  MatterUser[]
  attachments  MatterAttachment[]
  matterNotes  MatterNote[]
  diaryEntries DiaryEntry[]
  feeEntries   FeeEntry[]
  invoices     Invoice[]
  associatedAs    MatterAssociation[] @relation("PrimaryMatter")
  associations    MatterAssociation[] @relation("AssociatedMatter")
  trustEntries    TrustEntry[]
  businessEntries BusinessEntry[]
  journalLines    JournalLine[]

  @@map("matters")
}

model MatterUser {
  matterId    String   @map("matter_id")
  userId      String   @map("user_id")
  grantedById String   @map("granted_by")
  grantedAt   DateTime @default(now()) @map("granted_at")

  matter    Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user      User   @relation("MatterUserAccess", fields: [userId], references: [id])
  grantedBy User   @relation("MatterUserGrantedBy", fields: [grantedById], references: [id])

  @@id([matterId, userId])
  @@map("matter_users")
}

model MatterAssociation {
  matterId           String  @map("matter_id")
  associatedMatterId String  @map("associated_matter_id")
  relationshipNote   String? @map("relationship_note")

  matter           Matter @relation("PrimaryMatter", fields: [matterId], references: [id], onDelete: Cascade)
  associatedMatter Matter @relation("AssociatedMatter", fields: [associatedMatterId], references: [id], onDelete: Cascade)

  @@id([matterId, associatedMatterId])
  @@map("matter_associations")
}

model MatterAttachment {
  id            String   @id @default(uuid())
  matterId      String   @map("matter_id")
  fileName      String   @map("file_name")
  filePath      String   @map("file_path")
  fileSizeBytes Int?     @map("file_size_bytes")
  mimeType      String?  @map("mime_type")
  description   String?
  uploadedById  String   @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  matter     Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@map("matter_attachments")
}

model MatterNote {
  id          String     @id @default(uuid())
  matterId    String     @map("matter_id")
  content     String
  source      NoteSource @default(manual)
  feeEntryId  String?    @map("fee_entry_id")
  createdById String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  matter     Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("NoteCreatedBy", fields: [createdById], references: [id])
  feeEntry   FeeEntry? @relation(fields: [feeEntryId], references: [id], onDelete: SetNull)

  @@map("matter_notes")
}

model DiaryEntry {
  id           String    @id @default(uuid())
  matterId     String    @map("matter_id")
  title        String
  description  String?
  entryDate    DateTime  @default(now()) @map("entry_date")
  dueDate      DateTime  @map("due_date")
  assignedToId String?   @map("assigned_to")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdById  String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  matter     Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("DiaryAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User   @relation("DiaryCreatedBy", fields: [createdById], references: [id])

  @@map("diary_entries")
}

// ─── Phase 3: Time Recording ─────────────────────────────────────────────────

enum FeeEntryType {
  time
  unitary
  disbursement
}

model FeeEntry {
  id                    String       @id @default(uuid())
  matterId              String       @map("matter_id")
  entryType             FeeEntryType @map("entry_type")
  entryDate             DateTime     @map("entry_date") @db.Date
  narration             String

  // Time entries
  durationMinutesRaw    Int?         @map("duration_minutes_raw")
  durationMinutesBilled Int?         @map("duration_minutes_billed")

  // Unitary entries (stored as integer thousandths, e.g. 2500 = 2.500 units)
  unitQuantityThousandths Int?       @map("unit_quantity_thousandths")

  // Financials (all cents)
  rateCents             Int          @map("rate_cents")
  amountCents           Int          @map("amount_cents")
  discountPct           Int          @default(0) @map("discount_pct")
  discountCents         Int          @default(0) @map("discount_cents")
  totalCents            Int          @map("total_cents")

  isBillable            Boolean      @default(true) @map("is_billable")
  isInvoiced            Boolean      @default(false) @map("is_invoiced")

  // Receipt attachment (disbursements)
  receiptFileName       String?      @map("receipt_file_name")
  receiptFilePath       String?      @map("receipt_file_path")

  postingCodeId         String?      @map("posting_code_id")
  feeEarnerId           String       @map("fee_earner_id")
  createdById           String       @map("created_by_id")
  isHistorical          Boolean      @default(false) @map("is_historical")
  feeEarnerName         String?      @map("fee_earner_name")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  matter      Matter       @relation(fields: [matterId], references: [id])
  postingCode PostingCode? @relation(fields: [postingCodeId], references: [id])
  feeEarner   User         @relation("FeeEntryEarner", fields: [feeEarnerId], references: [id])
  createdBy   User         @relation("FeeEntryCreatedBy", fields: [createdById], references: [id])
  matterNotes MatterNote[]

  @@index([matterId])
  @@index([feeEarnerId])
  @@index([entryDate])
  @@map("fee_entries")
}

// ─── Phase 4: Invoicing ───────────────────────────────────────────────────────

enum InvoiceType {
  pro_forma
  invoice
}

enum InvoiceStatus {
  draft_pro_forma
  sent_pro_forma
  draft_invoice
  sent_invoice
  paid
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  invoiceType   InvoiceType   @map("invoice_type")
  status        InvoiceStatus @default(draft_pro_forma)

  matterId      String        @map("matter_id")
  clientId      String        @map("client_id")

  // Immutable snapshots captured at creation
  matterCode          String  @map("matter_code")
  matterDescription   String  @map("matter_description")
  clientName          String  @map("client_name")
  clientEmail         String? @map("client_email")
  firmName            String  @map("firm_name")
  firmAddress         String? @map("firm_address")
  firmTel             String? @map("firm_tel")
  firmEmail           String? @map("firm_email")
  firmWebsite         String? @map("firm_website")
  vatRegistered       Boolean @map("vat_registered")
  vatRateBps          Int     @map("vat_rate_bps")
  vatRegNumber        String? @map("vat_reg_number")
  trustBankName       String? @map("trust_bank_name")
  trustBankAccountName     String? @map("trust_bank_account_name")
  trustBankAccountNumber   String? @map("trust_bank_account_number")
  trustBankBranchCode      String? @map("trust_bank_branch_code")
  trustBankSwift           String? @map("trust_bank_swift")
  invoicePaymentInstructions String? @map("invoice_payment_instructions")

  // Financials
  subTotalCents Int     @map("sub_total_cents")
  vatCents      Int     @default(0) @map("vat_cents")
  totalCents    Int     @map("total_cents")

  invoiceDate   DateTime  @map("invoice_date") @db.Date
  sentAt        DateTime? @map("sent_at")
  paidAt        DateTime? @map("paid_at")
  paidNote      String?   @map("paid_note")

  isHistorical  Boolean   @default(false) @map("is_historical")

  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  matter    Matter          @relation(fields: [matterId], references: [id])
  client    Client          @relation(fields: [clientId], references: [id])
  createdBy User            @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]

  @@index([matterId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

// ─── Phase 5: Trust & Business Bookkeeping ───────────────────────────────────

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactName   String?  @map("contact_name")
  email         String?
  tel           String?
  vatNumber     String?  @map("vat_number")
  isActive      Boolean  @default(true) @map("is_active")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy       User            @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  trustEntries    TrustEntry[]
  businessEntries BusinessEntry[]

  @@map("suppliers")
}

enum TrustEntryType {
  trust_receipt
  trust_payment
  trust_transfer_in
  trust_transfer_out
  collection_receipt
}

model TrustEntry {
  id              String         @id @default(uuid())
  matterId        String         @map("matter_id")
  entryType       TrustEntryType @map("entry_type")
  entryDate       DateTime       @map("entry_date") @db.Date
  amountCents     Int            @map("amount_cents") // always positive; sign implied by entryType
  narration       String
  referenceNumber String?        @map("reference_number")
  chequeNumber    String?        @map("cheque_number")
  supplierId      String?        @map("supplier_id")
  linkedEntryId   String?        @unique @map("linked_entry_id") // links transfer pair
  createdById     String         @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  matter         Matter         @relation(fields: [matterId], references: [id])
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  createdBy      User           @relation("TrustEntryCreatedBy", fields: [createdById], references: [id])
  linkedEntry    TrustEntry?    @relation("TrustTransferLink", fields: [linkedEntryId], references: [id])
  linkedFrom     TrustEntry[]   @relation("TrustTransferLink")
  journalEntries JournalEntry[]
  bankMatches    BankMatch[]

  @@index([matterId])
  @@index([entryDate])
  @@map("trust_entries")
}

enum BusinessEntryType {
  matter_receipt
  matter_payment
  business_receipt
  business_payment
  supplier_invoice
  supplier_payment
  bank_transfer
  trust_to_business
}

model BusinessEntry {
  id              String            @id @default(uuid())
  matterId        String?           @map("matter_id") // nullable for firm-overhead entries
  entryType       BusinessEntryType @map("entry_type")
  entryDate       DateTime          @map("entry_date") @db.Date
  amountCents     Int               @map("amount_cents") // always positive
  narration       String
  referenceNumber String?           @map("reference_number")
  supplierId      String?           @map("supplier_id")
  linkedTrustEntryId String?        @map("linked_trust_entry_id")
  createdById     String            @map("created_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  matter        Matter?        @relation(fields: [matterId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  createdBy     User           @relation("BusinessEntryCreatedBy", fields: [createdById], references: [id])
  journalEntries JournalEntry[]
  bankMatches   BankMatch[]

  @@index([matterId])
  @@index([entryDate])
  @@map("business_entries")
}

// ─── Phase 5: General Ledger (Double-Entry) ───────────────────────────────────

enum GlAccountType {
  asset
  liability
  equity
  income
  expense
}

model GlAccount {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  accountType GlAccountType @map("account_type")
  isSystem    Boolean       @default(false) @map("is_system")
  isActive    Boolean       @default(true) @map("is_active")
  sortOrder   Int           @default(0) @map("sort_order")

  journalLines JournalLine[]

  @@map("gl_accounts")
}

model JournalEntry {
  id              String   @id @default(uuid())
  entryDate       DateTime @map("entry_date") @db.Date
  narration       String
  referenceNumber String?  @map("reference_number")
  trustEntryId    String?  @map("trust_entry_id")
  businessEntryId String?  @map("business_entry_id")
  createdAt       DateTime @default(now()) @map("created_at")

  trustEntry    TrustEntry?    @relation(fields: [trustEntryId], references: [id], onDelete: SetNull)
  businessEntry BusinessEntry? @relation(fields: [businessEntryId], references: [id], onDelete: SetNull)
  lines         JournalLine[]

  @@index([entryDate])
  @@index([trustEntryId])
  @@index([businessEntryId])
  @@map("journal_entries")
}

model JournalLine {
  id             String  @id @default(uuid())
  journalEntryId String  @map("journal_entry_id")
  accountId      String  @map("account_id")
  debitCents     Int     @default(0) @map("debit_cents")
  creditCents    Int     @default(0) @map("credit_cents")
  matterId       String? @map("matter_id") // sub-ledger tagging

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      GlAccount    @relation(fields: [accountId], references: [id])
  matter       Matter?      @relation(fields: [matterId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ─── Phase 6: Bank Statement Import & Reconciliation ─────────────────────────

enum BankAccountType {
  trust
  business
}

model BankStatement {
  id                  String          @id @default(uuid())
  accountType         BankAccountType @map("account_type")
  fileName            String          @map("file_name")
  accountNumber       String?         @map("account_number")
  accountDescription  String?         @map("account_description")
  statementFrom       DateTime?       @map("statement_from") @db.Date
  statementTo         DateTime?       @map("statement_to") @db.Date
  openingBalanceCents Int             @default(0) @map("opening_balance_cents")
  closingBalanceCents Int             @default(0) @map("closing_balance_cents")
  importedById        String          @map("imported_by_id")
  importedAt          DateTime        @default(now()) @map("imported_at")

  importedBy User                @relation("StatementImporter", fields: [importedById], references: [id])
  lines      BankStatementLine[]

  @@index([accountType])
  @@map("bank_statements")
}

model BankStatementLine {
  id              String   @id @default(uuid())
  bankStatementId String   @map("bank_statement_id")
  lineNumber      Int      @map("line_number")
  transactionDate DateTime @map("transaction_date") @db.Date
  amountCents     Int      @map("amount_cents")
  balanceCents    Int      @map("balance_cents")
  description     String
  reference       String?
  isReconciled    Boolean  @default(false) @map("is_reconciled")

  bankStatement BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  matches       BankMatch[]

  @@index([bankStatementId])
  @@index([transactionDate])
  @@map("bank_statement_lines")
}

model BankMatch {
  id                  String   @id @default(uuid())
  bankStatementLineId String   @map("bank_statement_line_id")
  trustEntryId        String?  @map("trust_entry_id")
  businessEntryId     String?  @map("business_entry_id")
  matchedById         String   @map("matched_by_id")
  matchedAt           DateTime @default(now()) @map("matched_at")
  notes               String?

  bankStatementLine BankStatementLine @relation(fields: [bankStatementLineId], references: [id], onDelete: Cascade)
  trustEntry        TrustEntry?       @relation(fields: [trustEntryId], references: [id], onDelete: SetNull)
  businessEntry     BusinessEntry?    @relation(fields: [businessEntryId], references: [id], onDelete: SetNull)
  matchedBy         User              @relation("BankMatchCreator", fields: [matchedById], references: [id])

  @@map("bank_matches")
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")

  // Snapshot of the fee entry (feeEntryId is informational only — not a FK)
  feeEntryId  String?  @map("fee_entry_id")
  entryDate   DateTime @map("entry_date") @db.Date
  entryType   String   @map("entry_type") // "time" | "unitary" | "disbursement"
  costCentre  String   @map("cost_centre")
  description String

  durationMinutesBilled   Int? @map("duration_minutes_billed")
  unitQuantityThousandths Int? @map("unit_quantity_thousandths")

  rateCents     Int  @map("rate_cents")
  amountCents   Int  @map("amount_cents")
  discountPct   Int  @default(0) @map("discount_pct")
  discountCents Int  @default(0) @map("discount_cents")
  totalCents    Int  @map("total_cents")

  sortOrder     Int  @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}
